{
  "name": "error-large-frame",
  "description": "Adapter sends a frame larger than the runtime's transport cap.",
  "ir": {
    "nodes": [
      {
        "id": "large-frame-check",
        "kind": "rule"
      }
    ]
  },
  "manifest": {
    "declared_outputs": [
      {
        "path": ".echo",
        "mode": "owned-subdir"
      }
    ],
    "capabilities": {
      "concept_kinds": {
        "rule": "supported"
      }
    }
  },
  "expect": {
    "kind": "error",
    "error": "ErrFrameTooLarge"
  }
}
