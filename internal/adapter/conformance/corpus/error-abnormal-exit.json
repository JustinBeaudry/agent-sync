{
  "name": "error-abnormal-exit",
  "description": "Adapter exits non-zero instead of completing the lifecycle.",
  "ir": {
    "nodes": [
      {
        "id": "crash-check",
        "kind": "rule"
      }
    ]
  },
  "manifest": {
    "declared_outputs": [
      {
        "path": ".echo",
        "mode": "owned-subdir"
      }
    ],
    "capabilities": {
      "concept_kinds": {
        "rule": "supported"
      }
    }
  },
  "expect": {
    "kind": "error",
    "error": "SubprocessExitError"
  }
}
